      "buildNumber": "6",
      "supportsTablet": false
    },
    "android": {
      "package": "ma.menmatarlmatar.app",
      "versionCode": 6
    },
    "extra": {
      "apiBaseUrl": "https://menmatarlmatar.ma"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
