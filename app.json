{
  "expo": {
    "name": "Men Matar L Matar",
    "slug": "men-matar-l-matar",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "menmatarlmatar",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo-sticker.png",
